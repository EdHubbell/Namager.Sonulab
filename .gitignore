# Wireshark / USBPcap captures — kept out of the repo by request (large, in parent folder)
*.pcapng
*.pcap

# Device slot backups (binary, machine/device-specific)
docs/backups/

# Probe run output (generated; regenerate with tools/probe.ps1)
docs/probe-output.txt

# .NET build output (future Avalonia app)
bin/
obj/
*.user
.vs/
__pycache__/
*.pyc

# Local distilled test outputs at repo root (corpus blobs in NAMFiles/ stay tracked)
/*.vxamp

# Corpus-derived goldens for Sonulab.Distill parity tests (regenerate via make_cs_fixtures.py --corpus)
tests/Sonulab.Distill.Tests/goldens-corpus/

# Tone3000 API keys - the real file lives in %APPDATA%\Namager\ and must
# never be committed; only tone3000.json.example belongs in the repo.
tone3000.json

# Feedback worker dev secrets (Cloudflare wrangler dev only)
infra/feedback-worker/.dev.vars

# Superpowers scratch (SDD ledger, briefs, brainstorm sessions)
.superpowers/
# Cloudflare wrangler local cache
infra/feedback-worker/.wrangler/
