<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Sonulab.App.ViewModels"
        xmlns:conv="using:Sonulab.App.Converters"
        x:Class="Sonulab.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1100" Height="700"
        MinWidth="800" MinHeight="500">

  <Design.DataContext>
    <vm:MainWindowViewModel/>
  </Design.DataContext>

  <DockPanel>

    <!-- ===== Top connection bar ===== -->
    <Border DockPanel.Dock="Top" Padding="12,8"
            Background="{DynamicResource Sonulab.SurfaceAltBrush}"
            BorderBrush="{DynamicResource Sonulab.BorderBrush}" BorderThickness="0,0,0,1">
      <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">

        <Button Classes="accent-outline" Command="{Binding Connection.ConnectCommand}"
                ToolTip.Tip="Connect to StompStation">
          <StackPanel Orientation="Horizontal">
            <PathIcon Data="{StaticResource Icon.Power}" Width="16" Height="16"/>
            <TextBlock Text="Connect" Margin="6,0,0,0" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>

        <Ellipse Width="12" Height="12" VerticalAlignment="Center"
                 Fill="{Binding Connection.IsConnected, Converter={x:Static conv:BoolToBrush.Connected}}"/>

        <TextBlock Text="{Binding Connection.Status}" VerticalAlignment="Center"/>

      </StackPanel>
    </Border>

    <!-- ===== SplitView: left nav pane + content ===== -->
    <SplitView DisplayMode="Inline" IsPaneOpen="True" OpenPaneLength="180">

      <SplitView.Pane>
        <ListBox x:Name="NavList" SelectionMode="Single" SelectedIndex="0" Margin="4">
          <ListBoxItem>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <PathIcon Data="{StaticResource Icon.List}" Width="16" Height="16"/>
              <TextBlock Text="Presets" VerticalAlignment="Center"/>
            </StackPanel>
          </ListBoxItem>
          <ListBoxItem>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <PathIcon Data="{StaticResource Icon.Power}" Width="16" Height="16"/>
              <TextBlock Text="Amps" VerticalAlignment="Center"/>
            </StackPanel>
          </ListBoxItem>
          <ListBoxItem>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <PathIcon Data="{StaticResource Icon.List}" Width="16" Height="16"/>
              <TextBlock Text="IRs" VerticalAlignment="Center"/>
            </StackPanel>
          </ListBoxItem>
          <ListBoxItem IsEnabled="False" MinHeight="0" Margin="0,10,0,0">
            <TextBlock Classes="section-label" Text="BROWSE TONES"/>
          </ListBoxItem>
          <ListBoxItem>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <PathIcon Data="{StaticResource Icon.List}" Width="16" Height="16"/>
              <TextBlock Text="Tone3000" VerticalAlignment="Center"/>
            </StackPanel>
          </ListBoxItem>
        </ListBox>
      </SplitView.Pane>

      <SplitView.Content>
        <Panel>

          <!-- Presets page: PresetListView (left 360) + ParameterEditorView (right) -->
          <Grid x:Name="PresetsPage"
                ColumnDefinitions="360,*"
                Margin="12">
            <ContentControl Grid.Column="0"
                            Content="{Binding Presets}"/>
            <ContentControl Grid.Column="1"
                            Content="{Binding Editor}" Margin="12,0,0,0"/>
          </Grid>

          <!-- Amps page -->
          <ContentControl x:Name="AmpsPage"
                          Content="{Binding Amps}"
                          Margin="12"
                          IsVisible="False"/>

          <!-- IRs page -->
          <ContentControl x:Name="IRsPage"
                          Content="{Binding Irs}"
                          Margin="12"
                          IsVisible="False"/>

          <!-- Tone3000 page (index 4; index 3 is the disabled section header) -->
          <ContentControl x:Name="Tone3000Page"
                          Content="{Binding Tone3000}"
                          Margin="12"
                          IsVisible="False"/>

        </Panel>
      </SplitView.Content>

    </SplitView>

  </DockPanel>

</Window>
